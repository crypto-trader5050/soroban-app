# ========================
# Python バイトコード・キャッシュ
# ========================
__pycache__/
*.py[cod]
*$py.class

# ========================
# 仮想環境関連（venv, pipenv, poetry）
# ========================
.venv/
venv/
env/
ENV/
.poetry/
.pipenv/
Pipfile.lock
poetry.lock

# ========================
